    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "cnfast": "^0.0.8",
    "date-fns-jalali": "4.4.0-0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.27",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "postgres": "^3.4.9",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
