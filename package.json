{
  "name": "toosheh",
  "version": "1.0.0",
  "description": "Secure & Fast Cloud Clipboard",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:gen": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:std": "drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe",
    "prepare": "husky"
