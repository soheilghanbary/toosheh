    "cmdk": "^1.1.1",
    "cnfast": "^0.0.8",
    "date-fns-jalali": "4.1.0-0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.21",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
