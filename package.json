  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "1.0.0-rc.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "tailwind-variants": "^3.2.2",
